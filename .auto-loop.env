# Auto-Company Loop Configuration
# Generated for Crash Crypto PVP Project

ENGINE=claude
MODEL=claude-fable-5
CLAUDE_PERMISSION_MODE=bypassPermissions
LOOP_INTERVAL=300
CYCLE_TIMEOUT_SECONDS=3600
MAX_CONSECUTIVE_ERRORS=3
COOLDOWN_SECONDS=600
LIMIT_WAIT_SECONDS=3600
MAX_LOGS=200
AUTO_LOOP_PROTECT_GITIGNORE=1

# Multi-model agent configuration
# Coordinator runs on fable, subagents use their own models
AGENT_MODELS_ENABLED=1


# Package manager override
PACKAGE_MANAGER=pnpm

